---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Payment Successful - DTing">
	<Header />

	<main>
		<section class="success-section">
			<div class="container">
				<div class="success-container glass-card">
					<div class="success-icon">
						<svg viewBox="0 0 24 24" width="80" height="80" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="12" cy="12" r="10"></circle>
							<polyline points="20 6 9 17 4 12"></polyline>
						</svg>
					</div>

					<h1 class="success-title">Payment Successful!</h1>
					<p class="success-message">
						Thank you for your purchase. Your subscription is now active.
					</p>

					<div class="success-actions">
						<a href="/dashboard" class="btn btn-primary">Go to Dashboard</a>
						<a href="/" class="btn btn-secondary">Back to Home</a>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>

<style>
	.success-section {
		padding: 6rem 0;
		min-height: calc(100vh - var(--header-height));
		display: flex;
		align-items: center;
	}

	.success-container {
		padding: 4rem 3rem;
		border-radius: 24px;
		max-width: 500px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.5rem;
		text-align: center;
	}

	.success-icon {
		color: #10b981;
		margin-bottom: 1rem;
	}

	.success-title {
		font-size: 2.5rem;
		font-weight: 800;
		background: var(--grad-primary);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.success-message {
		color: var(--text-secondary);
		font-size: 1.1rem;
		line-height: 1.6;
		max-width: 400px;
	}

	.success-actions {
		display: flex;
		gap: 1rem;
		margin-top: 1rem;
	}

	@media (max-width: 768px) {
		.success-section {
			padding: 4rem 0;
		}

		.success-container {
			padding: 3rem 1.5rem;
		}

		.success-title {
			font-size: 2rem;
		}
	}
</style>