---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const packages = [
	{
		id: 'free',
		name: 'Free',
		price: 0,
		priceLabel: 'Free',
		description: 'Basic access to core features',
		features: [
			'Access to public APIs',
			'100 requests/day',
			'Community support',
			'Basic documentation'
		],
		popular: false,
		buttonText: 'Get Started',
		buttonLink: '/signup'
	},
	{
		id: 'starter',
		name: 'Starter',
		price: 15,
		priceLabel: '$15',
		description: 'Perfect for individuals and small projects',
		features: [
			'All Free features',
			'10,000 requests/day',
			'Priority email support',
			'API analytics dashboard',
			'Webhook integrations',
			'Rate limit: 20 requests/sec'
		],
		popular: true,
		buttonText: 'Choose Starter',
		buttonLink: '/checkout'
	},
	{
		id: 'pro',
		name: 'Pro',
		price: 49,
		priceLabel: '$49',
		description: 'Ideal for growing businesses',
		features: [
			'All Starter features',
			'100,000 requests/day',
			'Dedicated support channel',
			'Advanced analytics',
			'Custom webhooks',
			'SSL certificates',
			'Rate limit: 100 requests/sec'
		],
		popular: false,
		buttonText: 'Go Pro',
		buttonLink: '/checkout'
	},
	{
		id: 'enterprise',
		name: 'Enterprise',
		price: 149,
		priceLabel: '$149',
		description: 'For large-scale applications',
		features: [
			'All Pro features',
			'Unlimited requests',
			'24/7 premium support',
			'SLA guarantees',
			'Custom API endpoint',
			'Dedicated infrastructure',
			'Rate limit: 500 requests/sec'
		],
		popular: false,
		buttonText: 'Contact Sales',
		buttonLink: '/contact'
	}
];
---

<Layout title="Billing - Choose Your Package | DTing">
	<Header />

	<main>
		<section class="billing-section">
			<div class="container">
				<div class="section-header text-center">
					<h1 class="section-title">Choose Your <span class="text-gradient">Package</span></h1>
					<p class="section-subtitle">Scale with confidence. All plans include our core API infrastructure and security.</p>
				</div>

				<div class="billing-grid">
					{packages.map((pkg) => (
						<div class={`billing-card glass-card ${pkg.popular ? 'popular' : ''}`}>
							{pkg.popular && (
								<div class="popular-badge">Most Popular</div>
							)}

							<h3 class="package-name">{pkg.name}</h3>
							<div class="package-price">
								<span class="price">{pkg.priceLabel}</span>
								{pkg.price > 0 && <span class="price-period">/month</span>}
							</div>
							<p class="package-desc">{pkg.description}</p>

							<ul class="package-features">
								{pkg.features.map((feature) => (
									<li class="feature-item">
										<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
											<polyline points="20 6 9 17 4 12"></polyline>
										</svg>
										{feature}
									</li>
								))}
							</ul>

							<a href={pkg.buttonLink} class={`btn ${pkg.popular ? 'btn-primary' : 'btn-outline-glow'}`}>
								{pkg.buttonText}
							</a>
						</div>
					))}
				</div>

				<div class="billing-note">
					<p>All prices are in USD. Cancel anytime. No hidden fees.</p>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>

<style>
	.billing-section {
		padding: 6rem 0;
		min-height: calc(100vh - var(--header-height));
		display: flex;
		align-items: center;
	}

	.section-header {
		margin-bottom: 4rem;
	}

	.section-title {
		font-size: clamp(2.5rem, 5vw, 3.5rem);
		font-weight: 800;
		margin-bottom: 1rem;
	}

	.section-subtitle {
		font-size: 1.125rem;
		color: var(--text-secondary);
		max-width: 600px;
		margin: 0 auto;
	}

	.billing-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 2rem;
		max-width: 1000px;
		margin: 0 auto;
	}

	.billing-card {
		padding: 2.5rem 2rem;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		position: relative;
		border: 1px solid var(--border-color);
		border-radius: 24px;
		background: rgba(255, 255, 255, 0.02);
		backdrop-filter: blur(12px);
	}

	.billing-card.popular {
		border-color: rgba(0, 242, 254, 0.4);
		box-shadow: 0 0 40px rgba(0, 242, 254, 0.15);
	}

	.billing-card:hover {
		transform: translateY(-8px);
		border-color: var(--border-hover);
		box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
	}

	.popular-badge {
		position: absolute;
		top: -12px;
		left: 50%;
		transform: translateX(-50%);
		background: var(--grad-primary);
		color: #07090e;
		font-size: 0.75rem;
		font-weight: 700;
		padding: 0.4rem 1rem;
		border-radius: 20px;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.package-name {
		font-size: 1.75rem;
		font-weight: 700;
		color: var(--text-primary);
		text-align: center;
	}

	.package-price {
		text-align: center;
		margin-bottom: 0.5rem;
	}

	.price {
		font-size: 3rem;
		font-weight: 800;
		background: var(--grad-primary);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.price-period {
		font-size: 1rem;
		color: var(--text-secondary);
		margin-left: 0.25rem;
	}

	.package-desc {
		text-align: center;
		color: var(--text-secondary);
		font-size: 0.95rem;
		line-height: 1.5;
	}

	.package-features {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin: 0.5rem 0;
	}

	.feature-item {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--text-secondary);
		font-size: 0.9rem;
	}

	.feature-item svg {
		color: var(--accent-cyan);
		flex-shrink: 0;
	}

	.btn {
		width: 100%;
		text-align: center;
		margin-top: auto;
	}

	.billing-note {
		text-align: center;
		margin-top: 3rem;
		color: var(--text-muted);
		font-size: 0.9rem;
	}

	@media (max-width: 768px) {
		.billing-section {
			padding: 4rem 0;
		}

		.billing-grid {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.billing-card {
			padding: 2rem 1.5rem;
		}
	}
</style>