---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="PocketPay - Secure Mobile Finance Tracker & P2P Ledger" description="Manage money, view instant transactions, and request funds with PocketPay's secure mobile application.">
	<Header />

	<main class="service-detail-page">
		<!-- Back Button & Breadcrumb -->
		<section class="breadcrumb-section">
			<div class="container">
				<a href="/#services" class="back-link">
					<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
					Back to Services
				</a>
			</div>
		</section>

		<!-- Hero Detail Grid -->
		<section class="detail-hero-section">
			<div class="container detail-hero-container">
				<div class="detail-hero-content">
					<div class="detail-badge purple">
						<span class="badge-dot purple-dot"></span>
						Finance Application
					</div>
					<h1 class="detail-title">PocketPay</h1>
					<p class="detail-tagline">Manage your wealth, ledger payments, and execute instant P2P transfers under a sleek, secured mobile application.</p>
					
					<div class="detail-ctas">
						<a href="#download" class="btn btn-primary">
							Download Application
							<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
						</a>
						<a href="#features" class="btn btn-secondary">Key Features</a>
					</div>
				</div>

				<div class="detail-hero-image-wrapper">
					<div class="image-frame-container">
						<img src="/pocketpay-preview.png" alt="PocketPay Mobile Application Dashboard UI" class="preview-image phone-mockup" />
					</div>
				</div>
			</div>
		</section>

		<!-- Features Grid -->
		<section class="detail-features-section" id="features">
			<div class="container">
				<h2 class="detail-section-title text-center">Core Features</h2>
				<div class="features-detail-grid">
					<div class="feat-detail-card glass-card">
						<div class="feat-icon finance-icon">
							<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12" y2="18"></line><line x1="2" y1="10" x2="22" y2="10"></line></svg>
						</div>
						<h3>Instant Transfers</h3>
						<p>Send and receive payments instantly with zero broker delay. All activities sync to your private dashboard ledger immediately.</p>
					</div>

					<div class="feat-detail-card glass-card">
						<div class="feat-icon security-icon">
							<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
						</div>
						<h3>Bank-Grade Cryptography</h3>
						<p>Encrypted using modern JWT tokens, hardware biometrics (FaceID/Fingerprint), and encrypted databases.</p>
					</div>

					<div class="feat-detail-card glass-card">
						<div class="feat-icon ledger-icon">
							<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>
						</div>
						<h3>Analytics & Tracking</h3>
						<p>Categorize spendings, view monthly budget charts, set saving goals, and generate CSV reports for taxes.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- How to Download Section -->
		<section class="download-section" id="download">
			<div class="container download-container glass-card">
				<div class="download-content">
					<h2>How to Download & Get Started</h2>
					<p class="download-summary">PocketPay is currently available on multiple mobile platforms. Follow the instructions to install the app on your device.</p>
					
					<div class="steps-list">
						<div class="step-item">
							<span class="step-number">1</span>
							<div class="step-text">
								<h4>Choose your device platform</h4>
								<p>Select either iOS App Store, Android Play Store, or download the direct APK installation bundle.</p>
							</div>
						</div>
						<div class="step-item">
							<span class="step-number">2</span>
							<div class="step-text">
								<h4>Download and Authenticate</h4>
								<p>Install the app, register with your email or connect via your existing DTing Auth platform account.</p>
							</div>
						</div>
						<div class="step-item">
							<span class="step-number">3</span>
							<div class="step-text">
								<h4>Link Ledger Wallet</h4>
								<p>Fund your wallet, configure transaction PIN, and start executing payments instantly.</p>
							</div>
						</div>
					</div>

					<div class="download-buttons">
						<a href="#" class="store-button apple-store">
							<svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M15.97 4.17c.66-.81 1.11-1.93.99-3.06-1 .04-2.21.67-2.93 1.49-.62.69-1.16 1.84-1.01 2.96 1.12.09 2.27-.58 2.95-1.39z"/></svg>
							<div>
								<span class="store-sub">Download on the</span>
								<span class="store-main">App Store</span>
							</div>
						</a>

						<a href="#" class="store-button play-store">
							<svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M5 3.14a1 1 0 0 0-.22.68v16.36a1 1 0 0 0 .22.68l9.06-9.06L5 3.14M15.19 12l3.85-3.85c.34-.2.66-.02.66.38v6.94c0 .4-.32.58-.66.38L15.19 12m-9.13-7.8l9.46 5.4 2.22-2.22-11.68-6.7c-.52-.3-.87-.04-.87.52v.4a1 1 0 0 0 .87.4m0 15.6c-.52.56-.17.82.35.52l11.33-6.5-2.22-2.22-9.46 5.4v.4a1 1 0 0 0-.01.4"/></svg>
							<div>
								<span class="store-sub">GET IT ON</span>
								<span class="store-main">Google Play</span>
							</div>
						</a>

						<a href="#" class="btn btn-secondary apk-btn">
							<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
							Download APK (54.2 MB)
						</a>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>

<style>
	/* Common styles for detail pages */
	.service-detail-page {
		padding-top: var(--header-height);
		flex-grow: 1;
	}

	.breadcrumb-section {
		padding: 2rem 0 1rem 0;
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--text-secondary);
		font-weight: 600;
		font-size: 0.95rem;
	}

	.back-link:hover {
		color: var(--text-primary);
		transform: translateX(-3px);
	}

	/* Hero Detail Section */
	.detail-hero-section {
		padding: 2rem 0 5rem 0;
	}

	.detail-hero-container {
		display: grid;
		grid-template-columns: 1.2fr 1fr;
		gap: 4rem;
		align-items: center;
	}

	.detail-hero-content {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.detail-badge {
		align-self: flex-start;
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.4rem 1rem;
		border-radius: 50px;
		font-size: 0.85rem;
		font-weight: 600;
		font-family: var(--font-heading);
	}

	.detail-badge.purple {
		background: rgba(127, 0, 255, 0.08);
		border: 1px solid rgba(127, 0, 255, 0.2);
		color: var(--accent-violet);
	}

	.badge-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
	}

	.purple-dot {
		background-color: var(--accent-violet);
		box-shadow: 0 0 8px var(--accent-violet);
	}

	.detail-title {
		font-size: 4rem;
		font-weight: 800;
		letter-spacing: -0.03em;
		line-height: 1.1;
	}

	.detail-tagline {
		color: var(--text-secondary);
		font-size: 1.2rem;
		line-height: 1.6;
	}

	.detail-ctas {
		display: flex;
		gap: 1rem;
		margin-top: 1rem;
	}

	/* Image display */
	.detail-hero-image-wrapper {
		display: flex;
		justify-content: center;
		width: 100%;
	}

	.image-frame-container {
		width: 100%;
		max-width: 420px;
		border-radius: 20px;
		padding: 8px;
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid var(--border-color);
		box-shadow: 0 30px 60px -20px rgba(0, 0, 0, 0.6);
	}

	.preview-image {
		border-radius: 14px;
		width: 100%;
		height: auto;
		object-fit: cover;
	}

	/* Features section */
	.detail-features-section {
		padding: 5rem 0;
		background: rgba(255, 255, 255, 0.01);
		border-top: 1px solid var(--border-color);
		border-bottom: 1px solid var(--border-color);
	}

	.detail-section-title {
		font-size: 2.25rem;
		margin-bottom: 3.5rem;
	}

	.features-detail-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.feat-detail-card {
		padding: 3rem 2.25rem;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.feat-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 50px;
		height: 50px;
		border-radius: 12px;
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid var(--border-color);
	}

	.finance-icon { color: var(--accent-purple); border-color: rgba(127, 0, 255, 0.2); }
	.security-icon { color: var(--accent-cyan); border-color: rgba(0, 242, 254, 0.2); }
	.ledger-icon { color: #10b981; border-color: rgba(16, 185, 129, 0.2); }

	.feat-detail-card h3 {
		font-size: 1.35rem;
		font-weight: 600;
	}

	.feat-detail-card p {
		color: var(--text-secondary);
		font-size: 0.95rem;
		line-height: 1.6;
	}

	/* Download Section */
	.download-section {
		padding: 6rem 0 8rem 0;
	}

	.download-container {
		padding: 5rem 4.5rem;
		border: 1px solid rgba(127, 0, 255, 0.15);
	}

	.download-content {
		max-width: 700px;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.download-content h2 {
		font-size: 2.25rem;
	}

	.download-summary {
		color: var(--text-secondary);
		font-size: 1.05rem;
	}

	.steps-list {
		display: flex;
		flex-direction: column;
		gap: 1.75rem;
		margin: 1.5rem 0;
	}

	.step-item {
		display: flex;
		gap: 1.25rem;
	}

	.step-number {
		display: flex;
		align-items: center;
		justify-content: center;
		min-width: 32px;
		height: 32px;
		border-radius: 50%;
		background: rgba(127, 0, 255, 0.1);
		border: 1px solid rgba(127, 0, 255, 0.3);
		color: var(--accent-violet);
		font-family: var(--font-heading);
		font-weight: bold;
		font-size: 0.9rem;
	}

	.step-text h4 {
		font-size: 1.05rem;
		font-weight: 600;
		margin-bottom: 0.25rem;
	}

	.step-text p {
		color: var(--text-secondary);
		font-size: 0.95rem;
		line-height: 1.5;
	}

	.download-buttons {
		display: flex;
		flex-wrap: wrap;
		gap: 1.25rem;
		margin-top: 1.5rem;
		align-items: center;
	}

	.store-button {
		display: inline-flex;
		align-items: center;
		gap: 0.85rem;
		background: #ffffff;
		color: #07090e;
		padding: 0.65rem 1.5rem;
		border-radius: 12px;
		transition: all 0.3s ease;
		box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
	}

	.store-button:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
		opacity: 0.95;
	}

	.store-sub {
		display: block;
		font-size: 0.7rem;
		text-transform: uppercase;
		font-weight: 600;
		letter-spacing: 0.05em;
		opacity: 0.8;
		line-height: 1;
	}

	.store-main {
		display: block;
		font-family: var(--font-heading);
		font-size: 1.15rem;
		font-weight: 700;
		line-height: 1.2;
	}

	.apk-btn {
		height: 48px;
		border-radius: 12px;
		font-size: 0.95rem;
	}

	/* Responsive Breakpoints */
	@media (max-width: 992px) {
		.detail-hero-container {
			grid-template-columns: 1fr;
			text-align: center;
			gap: 4rem;
		}

		.detail-badge {
			align-self: center;
		}

		.detail-ctas {
			justify-content: center;
		}

		.features-detail-grid {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.download-container {
			padding: 4rem 2.5rem;
		}
	}

	@media (max-width: 576px) {
		.detail-title {
			font-size: 3rem;
		}
		
		.download-buttons {
			flex-direction: column;
			align-items: stretch;
		}
		
		.store-button {
			justify-content: center;
		}
	}
</style>
