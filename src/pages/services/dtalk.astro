---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="DTalk - Next-Gen Encrypted Messaging & Collaboration" description="Communicate securely with your team using DTalk. Enjoy end-to-end encryption, custom channels, and rapid file transfers.">
	<Header />

	<main class="service-detail-page">
		<!-- Back Button & Breadcrumb -->
		<section class="breadcrumb-section">
			<div class="container">
				<a href="/#services" class="back-link">
					<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
					Back to Services
				</a>
			</div>
		</section>

		<!-- Hero Detail Grid -->
		<section class="detail-hero-section">
			<div class="container detail-hero-container">
				<div class="detail-hero-content">
					<div class="detail-badge pink">
						<span class="badge-dot pink-dot"></span>
						Communication Platform
					</div>
					<h1 class="detail-title">DTalk Messenger</h1>
					<p class="detail-tagline">A powerful, real-time messaging ecosystem. Create dedicated workspaces, encrypted direct messages, and collaborate instantly across all your devices.</p>
					
					<div class="detail-ctas">
						<a href="#download" class="btn btn-primary">
							Get Desktop App
							<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
						</a>
						<a href="#features" class="btn btn-secondary">Platform Features</a>
					</div>
				</div>

				<div class="detail-hero-image-wrapper">
					<div class="image-frame-container">
						<img src="/dtalk-preview.png" alt="DTalk Desktop Chat Dashboard UI" class="preview-image desktop-mockup" />
					</div>
				</div>
			</div>
		</section>

		<!-- Features Grid -->
		<section class="detail-features-section" id="features">
			<div class="container">
				<h2 class="detail-section-title text-center">Collaboration Reimagined</h2>
				<div class="features-detail-grid">
					<div class="feat-detail-card glass-card">
						<div class="feat-icon channel-icon">
							<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
						</div>
						<h3>Workspace Channels</h3>
						<p>Organize discussions by project, department, or topic. Keep conversations focused and teams aligned in dedicated spaces.</p>
					</div>

					<div class="feat-detail-card glass-card">
						<div class="feat-icon lock-icon">
							<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
						</div>
						<h3>End-to-End Encryption</h3>
						<p>Your privacy is absolute. Direct messages and sensitive files are fully encrypted end-to-end, meaning only the recipient can decrypt them.</p>
					</div>

					<div class="feat-detail-card glass-card">
						<div class="feat-icon file-icon">
							<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path><polyline points="13 2 13 9 20 9"></polyline></svg>
						</div>
						<h3>Lightning File Transfer</h3>
						<p>Share heavy design assets, documents, and code snippets directly within the chat interface, backed by DTing's high-speed cloud infrastructure.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Download Section -->
		<section class="download-section" id="download">
			<div class="container download-container glass-card">
				<div class="download-content">
					<h2>Download DTalk for Desktop</h2>
					<p class="download-summary">Experience the full power of DTalk natively. Available for all major desktop operating systems with optimized electron wrappers for maximum performance.</p>
					
					<div class="download-platforms">
						<div class="platform-card glass-card">
							<div class="platform-icon">
								<svg viewBox="0 0 24 24" width="32" height="32" fill="currentColor"><path d="M12.02 0C5.38 0 0 5.38 0 12s5.38 12 12.02 12S24 18.62 24 12 18.66 0 12.02 0zm0 1.5c5.8 0 10.5 4.7 10.5 10.5S17.82 22.5 12.02 22.5 1.5 17.8 1.5 12 6.22 1.5 12.02 1.5z"></path></svg>
							</div>
							<h4>macOS</h4>
							<p>Supports Intel & Apple Silicon</p>
							<a href="#" class="btn btn-outline-glow btn-sm">Download .dmg</a>
						</div>

						<div class="platform-card glass-card">
							<div class="platform-icon">
								<svg viewBox="0 0 24 24" width="32" height="32" fill="currentColor"><path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-13.051-1.801"/></svg>
							</div>
							<h4>Windows</h4>
							<p>Windows 10 / 11 (64-bit)</p>
							<a href="#" class="btn btn-outline-glow btn-sm">Download .exe</a>
						</div>

						<div class="platform-card glass-card">
							<div class="platform-icon">
								<svg viewBox="0 0 24 24" width="32" height="32" fill="currentColor"><path d="M12.016 1.134L4 5.76l8.016 4.625L20 5.76zm-.032 9.25L4.016 5.76v9.25l7.968 4.625V10.384zm.064.067V24l8.016-4.625V5.827z"/></svg>
							</div>
							<h4>Linux</h4>
							<p>Debian, Ubuntu, & Arch</p>
							<a href="#" class="btn btn-outline-glow btn-sm">Download .AppImage</a>
						</div>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>

<style>
	/* Common styles matching pocketpay.astro */
	.service-detail-page {
		padding-top: var(--header-height);
		flex-grow: 1;
	}

	.breadcrumb-section {
		padding: 2rem 0 1rem 0;
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--text-secondary);
		font-weight: 600;
		font-size: 0.95rem;
	}

	.back-link:hover {
		color: var(--text-primary);
		transform: translateX(-3px);
	}

	/* Hero Detail Section */
	.detail-hero-section {
		padding: 2rem 0 5rem 0;
	}

	.detail-hero-container {
		display: grid;
		grid-template-columns: 1.2fr 1fr;
		gap: 4rem;
		align-items: center;
	}

	.detail-hero-content {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.detail-badge {
		align-self: flex-start;
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.4rem 1rem;
		border-radius: 50px;
		font-size: 0.85rem;
		font-weight: 600;
		font-family: var(--font-heading);
	}

	.detail-badge.pink {
		background: rgba(243, 85, 136, 0.08);
		border: 1px solid rgba(243, 85, 136, 0.2);
		color: var(--accent-pink);
	}

	.badge-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
	}

	.pink-dot {
		background-color: var(--accent-pink);
		box-shadow: 0 0 8px var(--accent-pink);
	}

	.detail-title {
		font-size: 4rem;
		font-weight: 800;
		letter-spacing: -0.03em;
		line-height: 1.1;
	}

	.detail-tagline {
		color: var(--text-secondary);
		font-size: 1.2rem;
		line-height: 1.6;
	}

	.detail-ctas {
		display: flex;
		gap: 1rem;
		margin-top: 1rem;
	}

	/* Image display */
	.detail-hero-image-wrapper {
		display: flex;
		justify-content: center;
		width: 100%;
	}

	.image-frame-container {
		width: 100%;
		max-width: 550px;
		border-radius: 12px;
		padding: 6px;
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid var(--border-color);
		box-shadow: 0 30px 60px -20px rgba(0, 0, 0, 0.6);
	}

	.preview-image {
		border-radius: 8px;
		width: 100%;
		height: auto;
		object-fit: cover;
	}

	/* Features section */
	.detail-features-section {
		padding: 5rem 0;
		background: rgba(255, 255, 255, 0.01);
		border-top: 1px solid var(--border-color);
		border-bottom: 1px solid var(--border-color);
	}

	.detail-section-title {
		font-size: 2.25rem;
		margin-bottom: 3.5rem;
	}

	.features-detail-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.feat-detail-card {
		padding: 3rem 2.25rem;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.feat-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 50px;
		height: 50px;
		border-radius: 12px;
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid var(--border-color);
	}

	.channel-icon { color: var(--accent-cyan); border-color: rgba(0, 242, 254, 0.2); }
	.lock-icon { color: #10b981; border-color: rgba(16, 185, 129, 0.2); }
	.file-icon { color: var(--accent-pink); border-color: rgba(243, 85, 136, 0.2); }

	.feat-detail-card h3 {
		font-size: 1.35rem;
		font-weight: 600;
	}

	.feat-detail-card p {
		color: var(--text-secondary);
		font-size: 0.95rem;
		line-height: 1.6;
	}

	/* Download Section */
	.download-section {
		padding: 6rem 0 8rem 0;
	}

	.download-container {
		padding: 5rem 4.5rem;
		border: 1px solid rgba(243, 85, 136, 0.15);
	}

	.download-content {
		width: 100%;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		text-align: center;
		align-items: center;
	}

	.download-content h2 {
		font-size: 2.25rem;
	}

	.download-summary {
		color: var(--text-secondary);
		font-size: 1.05rem;
		max-width: 600px;
		margin-bottom: 2rem;
	}

	.download-platforms {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
		width: 100%;
	}

	.platform-card {
		padding: 2.5rem 2rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 1rem;
	}

	.platform-icon {
		margin-bottom: 0.5rem;
		color: var(--text-primary);
	}

	.platform-card h4 {
		font-size: 1.2rem;
		font-weight: 600;
	}

	.platform-card p {
		color: var(--text-secondary);
		font-size: 0.9rem;
		margin-bottom: 1rem;
	}

	/* Responsive Breakpoints */
	@media (max-width: 992px) {
		.detail-hero-container {
			grid-template-columns: 1fr;
			text-align: center;
			gap: 4rem;
		}

		.detail-badge {
			align-self: center;
		}

		.detail-ctas {
			justify-content: center;
		}

		.features-detail-grid {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.download-container {
			padding: 4rem 2.5rem;
		}

		.download-platforms {
			grid-template-columns: 1fr;
			gap: 1.5rem;
			max-width: 400px;
		}
	}

	@media (max-width: 576px) {
		.detail-title {
			font-size: 3rem;
		}
	}
</style>
