---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Image Toolkit - Client-Side Crop, Compress & Converter" description="Process images securely. Crop, compress, resize, and convert images inside your web browser without uploading to any server.">
	<Header />

	<main class="service-detail-page">
		<!-- Back Button & Breadcrumb -->
		<section class="breadcrumb-section">
			<div class="container">
				<a href="/#services" class="back-link">
					<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
					Back to Services
				</a>
			</div>
		</section>

		<!-- Hero Detail Grid -->
		<section class="detail-hero-section">
			<div class="container detail-hero-container">
				<div class="detail-hero-content">
					<div class="detail-badge cyan">
						<span class="badge-dot cyan-dot"></span>
						Client-Side Utility
					</div>
					<h1 class="detail-title">Image Toolkit</h1>
					<p class="detail-tagline">Compress, crop, resize, and convert image formats locally. Zero server uploads, guaranteeing absolute file privacy.</p>
					
					<div class="detail-ctas">
						<a href="#integration" class="btn btn-primary">
							Get Local Copy
							<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
						</a>
						<a href="#features" class="btn btn-secondary">Key Features</a>
					</div>
				</div>

				<div class="detail-hero-image-wrapper">
					<div class="image-frame-container">
						<img src="/toolkit-preview.png" alt="DTing Image Toolkit UI Workbench" class="preview-image desktop-mockup" />
					</div>
				</div>
			</div>
		</section>

		<!-- Features Grid -->
		<section class="detail-features-section" id="features">
			<div class="container">
				<h2 class="detail-section-title text-center">Core Operations</h2>
				<div class="features-detail-grid">
					<div class="feat-detail-card glass-card">
						<div class="feat-icon compress-icon">
							<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14h6v6"></path><path d="M20 10h-6V4"></path><path d="M14 10l7-7"></path><path d="M10 14l-7 7"></path></svg>
						</div>
						<h3>Lossless Compression</h3>
						<p>Reduce file weights up to 90% without sacrificing visual fidelity. Choose quality sliders to control compression ratios.</p>
					</div>

					<div class="feat-detail-card glass-card">
						<div class="feat-icon crop-icon">
							<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2v16h16"></path><path d="M18 22V6H2"></path></svg>
						</div>
						<h3>Aspect Ratio Crop</h3>
						<p>Crop images freely or lock presets (16:9, 4:3, 1:1 square). An interactive canvas ensures you get the exact frame.</p>
					</div>

					<div class="feat-detail-card glass-card">
						<div class="feat-icon convert-icon">
							<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 2.1l4 4-4 4"></path><path d="M3 12.2v-2a4 4 0 0 1 4-4h14"></path><path d="M7 21.9l-4-4 4-4"></path><path d="M21 11.8v2a4 4 0 0 1-4 4H3"></path></svg>
						</div>
						<h3>Format Converter</h3>
						<p>Instantly convert images between PNG, JPEG, WebP, AVIF, and GIF. Fully compatible with major browser rendering cores.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- How to Use / Run Locally -->
		<section class="integration-section" id="integration">
			<div class="container integration-container glass-card">
				<div class="integration-content">
					<h2>Run the Image Toolkit Locally</h2>
					<p class="integration-summary">Want to host or run the Image Toolkit on your own device? We've designed it to be fully self-contained. Follow these steps to set it up.</p>
					
					<div class="steps-list">
						<div class="step-item">
							<span class="step-number">1</span>
							<div class="step-text">
								<h4>Clone the Repository</h4>
								<p>Grab the source files directly from our repository system.</p>
								<div class="code-block-wrapper">
									<pre><code>git clone https://github.com/dting-online/image-toolkit.git</code></pre>
								</div>
							</div>
						</div>
						
						<div class="step-item">
							<span class="step-number">2</span>
							<div class="step-text">
								<h4>Install Dependencies</h4>
								<p>Navigate into the directory and install local packages using npm or yarn.</p>
								<div class="code-block-wrapper">
									<pre><code>cd image-toolkit && npm install</code></pre>
								</div>
							</div>
						</div>

						<div class="step-item">
							<span class="step-number">3</span>
							<div class="step-text">
								<h4>Boot Dev Server</h4>
								<p>Start a local dev server and open your browser at the default port.</p>
								<div class="code-block-wrapper">
									<pre><code>npm run dev</code></pre>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>

<style>
	/* Common styles matching pocketpay.astro */
	.service-detail-page {
		padding-top: var(--header-height);
		flex-grow: 1;
	}

	.breadcrumb-section {
		padding: 2rem 0 1rem 0;
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--text-secondary);
		font-weight: 600;
		font-size: 0.95rem;
	}

	.back-link:hover {
		color: var(--text-primary);
		transform: translateX(-3px);
	}

	/* Hero Detail Section */
	.detail-hero-section {
		padding: 2rem 0 5rem 0;
	}

	.detail-hero-container {
		display: grid;
		grid-template-columns: 1.2fr 1fr;
		gap: 4rem;
		align-items: center;
	}

	.detail-hero-content {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.detail-badge {
		align-self: flex-start;
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.4rem 1rem;
		border-radius: 50px;
		font-size: 0.85rem;
		font-weight: 600;
		font-family: var(--font-heading);
	}

	.detail-badge.cyan {
		background: rgba(0, 242, 254, 0.08);
		border: 1px solid rgba(0, 242, 254, 0.2);
		color: var(--accent-cyan);
	}

	.badge-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
	}

	.cyan-dot {
		background-color: var(--accent-cyan);
		box-shadow: 0 0 8px var(--accent-cyan);
	}

	.detail-title {
		font-size: 4rem;
		font-weight: 800;
		letter-spacing: -0.03em;
		line-height: 1.1;
	}

	.detail-tagline {
		color: var(--text-secondary);
		font-size: 1.2rem;
		line-height: 1.6;
	}

	.detail-ctas {
		display: flex;
		gap: 1rem;
		margin-top: 1rem;
	}

	/* Image display */
	.detail-hero-image-wrapper {
		display: flex;
		justify-content: center;
		width: 100%;
	}

	.image-frame-container {
		width: 100%;
		max-width: 500px;
		border-radius: 12px;
		padding: 6px;
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid var(--border-color);
		box-shadow: 0 30px 60px -20px rgba(0, 0, 0, 0.6);
	}

	.preview-image {
		border-radius: 8px;
		width: 100%;
		height: auto;
		object-fit: cover;
	}

	/* Features section */
	.detail-features-section {
		padding: 5rem 0;
		background: rgba(255, 255, 255, 0.01);
		border-top: 1px solid var(--border-color);
		border-bottom: 1px solid var(--border-color);
	}

	.detail-section-title {
		font-size: 2.25rem;
		margin-bottom: 3.5rem;
	}

	.features-detail-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.feat-detail-card {
		padding: 3rem 2.25rem;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.feat-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 50px;
		height: 50px;
		border-radius: 12px;
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid var(--border-color);
	}

	.compress-icon { color: var(--accent-cyan); border-color: rgba(0, 242, 254, 0.2); }
	.crop-icon { color: var(--accent-pink); border-color: rgba(243, 85, 136, 0.2); }
	.convert-icon { color: var(--accent-purple); border-color: rgba(127, 0, 255, 0.2); }

	.feat-detail-card h3 {
		font-size: 1.35rem;
		font-weight: 600;
	}

	.feat-detail-card p {
		color: var(--text-secondary);
		font-size: 0.95rem;
		line-height: 1.6;
	}

	/* Integration / Local setup section */
	.integration-section {
		padding: 6rem 0 8rem 0;
	}

	.integration-container {
		padding: 5rem 4.5rem;
		border: 1px solid rgba(0, 242, 254, 0.15);
	}

	.integration-content {
		max-width: 800px;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.integration-content h2 {
		font-size: 2.25rem;
	}

	.integration-summary {
		color: var(--text-secondary);
		font-size: 1.05rem;
	}

	.steps-list {
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
		margin: 1.5rem 0;
	}

	.step-item {
		display: flex;
		gap: 1.5rem;
	}

	.step-number {
		display: flex;
		align-items: center;
		justify-content: center;
		min-width: 36px;
		height: 36px;
		border-radius: 50%;
		background: rgba(0, 242, 254, 0.1);
		border: 1px solid rgba(0, 242, 254, 0.3);
		color: var(--accent-cyan);
		font-family: var(--font-heading);
		font-weight: bold;
		font-size: 0.95rem;
	}

	.step-text {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		flex-grow: 1;
	}

	.step-text h4 {
		font-size: 1.15rem;
		font-weight: 600;
	}

	.step-text p {
		color: var(--text-secondary);
		font-size: 0.95rem;
		line-height: 1.5;
	}

	/* Code Block styling */
	.code-block-wrapper {
		background: rgba(7, 9, 14, 0.6);
		border: 1px solid var(--border-color);
		border-radius: 8px;
		padding: 0.85rem 1.25rem;
		margin-top: 0.5rem;
		max-width: 100%;
		overflow-x: auto;
	}

	.code-block-wrapper pre {
		margin: 0;
	}

	.code-block-wrapper code {
		font-family: 'Courier New', Courier, monospace;
		color: #e2e8f0;
		font-size: 0.9rem;
	}

	/* Responsive Breakpoints */
	@media (max-width: 992px) {
		.detail-hero-container {
			grid-template-columns: 1fr;
			text-align: center;
			gap: 4rem;
		}

		.detail-badge {
			align-self: center;
		}

		.detail-ctas {
			justify-content: center;
		}

		.features-detail-grid {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.integration-container {
			padding: 4rem 2.5rem;
		}
	}

	@media (max-width: 576px) {
		.detail-title {
			font-size: 3rem;
		}
	}
</style>
